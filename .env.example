# Ortam değişkenleri örneği. Bu dosyayı `.env` olarak kopyalayın (git'e girmez) veya
# değişkenleri kabuğunuzda export edin. Üretimde JWT_SECRET ZORUNLUDUR (yoksa servis açılmaz).

# JWT imzalama sırrı. Güçlü rastgele bir değer üretin, örn:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Üretim modunu işaretler. production iken JWT_SECRET set değilse servisler gürültülü hata verir.
# Node: NODE_ENV=production | Python: ENV=production
# NODE_ENV=production
# ENV=production
